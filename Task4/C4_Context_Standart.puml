@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/refs/heads/master/C4_Container.puml

Person(Customer, "Клиент")
Person(CallcenterStaff, "Работник колл-центра")
Person(ExtCallcenterStaff, "Работник партнёрского колл-центра")
Person(BackofficeStaff, "Работник бэк-оффиса")

System_Ext(ExtCallcenter, "Партнёрский кол-центр")
System(BankSystems, "Внутренние системы Банка")
System_Ext(ExtSTMP, "Партнёрский почтовый сервер")

Rel(Customer, CallcenterStaff, "Обращается к работнику кол-центра")
Rel(Customer, ExtCallcenterStaff, "Обращается к работнику партнёрского кол-центра")
Rel(CallcenterStaff, BankSystems, "Работает в системе кол-центра")
Rel(ExtCallcenterStaff, ExtCallcenter, "Работает в системе партнёрского кол-центра")
Rel(BankSystems, ExtSTMP, "Передаёт файл с актуальными ставками")
Rel(BackofficeStaff, BankSystems, "Актуализирует ставки по депозитам")
Rel(ExtCallcenter, ExtSTMP, "Получает актуальные ставки по депозитам")

@enduml