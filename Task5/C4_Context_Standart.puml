@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/refs/heads/master/C4_Container.puml

Person(Customer, "Клиент")
Person(FrontofficeStaff, "Работник фронт-офиса")
Person(BackofficeStaff, "Работник отдела кредитования")

System(Site, "Сайт Банка", "Используется новыми клиентами Банка")
System(InternetBank, "Интернет-банк", "Используется действующими клиентами Банка")
System(BankSystems, "Внутренние системы Банка", "Обрабатывает информацию о клиентах и кредитных заявках")
System_Ext(SMSOperator, "Телеком оператор")
System_Ext(CreditBuro, "Бюро кредитных историй")

Rel(Customer, Site, "Подаёт заявку на кредит")
Rel(Customer, InternetBank, "Подает заявку на кредит")
Rel(Customer, FrontofficeStaff, "Обращается в офис для идентификации")
Rel(FrontofficeStaff, BankSystems, "Идентифицирует клиента")

Rel(Site, BankSystems, "Передаёт информацию о заявке на кредит")
Rel(InternetBank, BankSystems, "Передаёт информацию о заявке на кредит")
Rel(BankSystems, CreditBuro, "Запрашивает информацию о кредитной истории клиента")
Rel(BankSystems, SMSOperator, "Инициирует отправку СМС-уведомления о статусе заявки")
Rel(SMSOperator, Customer, "Отправляет СМС-уведомление о статусе заявки")
Rel(BackofficeStaff, BankSystems, "Обрабатывает кредитные заявки")


@enduml